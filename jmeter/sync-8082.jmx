        <collectionProp name="Arguments.arguments">
          <elementProp name="trainId" elementType="Argument">
            <stringProp name="Argument.name">trainId</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="departure" elementType="Argument">
            <stringProp name="Argument.name">departure</stringProp>
            <stringProp name="Argument.value">北京南</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="arrival" elementType="Argument">
            <stringProp name="Argument.name">arrival</stringProp>
            <stringProp name="Argument.value">南京南</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="userId" elementType="Argument">
            <stringProp name="Argument.name">userId</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="seatType" elementType="Argument">
            <stringProp name="Argument.name">seatType</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="passengerId" elementType="Argument">
            <stringProp name="Argument.name">passengerId</stringProp>
            <stringProp name="Argument.value">1</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
        <stringProp name="TestPlan.comments">trainId = 1
departure = 北京南
arrival = 南京南
userId = 1
seatType = 1
passengerId = 1</stringProp>
      </Arguments>
